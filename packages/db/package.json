{
  "name": "@coup-online/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./schema": {
      "types": "./dist/schema.d.ts",
      "default": "./dist/schema.js"
    }
  },
  "files": ["dist", "drizzle"],
  "scripts": {
    "build": "tsc",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "generate": "drizzle-kit generate",
    "migrations:list": "drizzle-kit list"
  },
  "dependencies": {
    "drizzle-orm": "^0.36"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4",
    "@eslint/js": "^9",
    "drizzle-kit": "^0.28",
    "eslint": "^9",
    "typescript": "^5",
    "typescript-eslint": "^8"
  }
}
